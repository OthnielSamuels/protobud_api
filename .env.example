# =============================================================
# .env.example
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================

# -----------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------
POSTGRES_DB=printbot
POSTGRES_USER=printbot
POSTGRES_PASSWORD=change_me_in_production

# Built automatically by docker-compose — no need to set manually:
# DATABASE_URL=postgresql://printbot:...@postgres:5432/printbot?connection_limit=5

# -----------------------------------------------------------
# NestJS
# -----------------------------------------------------------
PORT=3000
NODE_ENV=production

# -----------------------------------------------------------
# Ollama
# -----------------------------------------------------------
# Model to use — must match what's pulled in ollama/entrypoint.sh
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M

# Internal Docker network address — do not change unless renaming services
OLLAMA_HOST=http://ollama:11434

# Request timeout in ms — Qwen 3.5 4B Q4 can take 15–60s depending on load
OLLAMA_TIMEOUT_MS=60000

# Max retries on Ollama failure (with exponential backoff)
OLLAMA_MAX_RETRIES=2

# -----------------------------------------------------------
# WhatsApp Bot
# -----------------------------------------------------------
# Internal Docker network address of NestJS backend
BACKEND_URL=http://nestjs-backend:3000

# Internal HTTP server port on the bot container
BOT_HTTP_PORT=3001

# Internal Docker network address of the bot (used by NestJS to send messages)
WHATSAPP_BOT_URL=http://whatsapp-bot:3001

# How long NestJS waits for the LLM to respond before timing out
# Must be > OLLAMA_TIMEOUT_MS to avoid premature WhatsApp bot timeout
REQUEST_TIMEOUT_MS=90000
